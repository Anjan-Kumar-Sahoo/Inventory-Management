# -----------------------------
# Runtime and Docker image
# -----------------------------
BACKEND_IMAGE=docker.io/aksahoo1097/godamm-backend:replace-with-git-sha
BACKEND_PORT=8080

# -----------------------------
# Database (MySQL)
# -----------------------------
MYSQL_DATABASE=inventory_db
MYSQL_USER=inventory_app
MYSQL_PASSWORD=change_this_app_password
MYSQL_ROOT_PASSWORD=change_this_root_password
MYSQL_PORT=3306

DB_URL=jdbc:mysql://mysql:3306/inventory_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
# For AWS RDS, replace DB_URL with your endpoint, e.g. jdbc:mysql://<rds-endpoint>:3306/godamm?useSSL=true&requireSSL=true&serverTimezone=UTC
DB_USERNAME=inventory_app
DB_PASSWORD=change_this_app_password
DB_POOL_MAX_SIZE=20
DB_POOL_MIN_IDLE=5

# -----------------------------
# JWT and API security
# -----------------------------
JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars
JWT_EXPIRATION_MS=86400000
REQUIRE_HTTPS=true
CORS_ALLOWED_ORIGINS=https://godamm.mraks.dev,https://godamm.anjaliv.dev

# -----------------------------
# Redis
# -----------------------------
CACHE_PROVIDER=redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_this_redis_password
REDIS_TIMEOUT=2s

# -----------------------------
# Email (OTP)
# -----------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-mail-password

# -----------------------------
# Rate limiting and observability
# -----------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_FAIL_OPEN=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS_PER_MINUTE=240
RATE_LIMIT_AUTH_MAX_REQUESTS_PER_MINUTE=60
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_SECURITY=INFO

# -----------------------------
# Frontend (Vercel)
# -----------------------------
VITE_API_BASE_URL=https://api.godamm.mraks.dev
