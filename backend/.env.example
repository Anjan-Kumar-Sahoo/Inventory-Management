# Database
DB_URL=jdbc:mysql://localhost:3306/inventory_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=inventory_app
DB_PASSWORD=change_this_app_password
DB_POOL_MAX_SIZE=20
DB_POOL_MIN_IDLE=5

# JWT
JWT_SECRET=ReplaceWithLongRandomSecretAtLeast32Chars
JWT_EXPIRATION_MS=86400000

# OTP
OTP_EXPIRATION_MINUTES=10

# Redis
CACHE_PROVIDER=redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_this_redis_password

# Mail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-app-password

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://godamm.mraks.dev,https://godamm.anjaliv.dev

# Security and limits
REQUIRE_HTTPS=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS_PER_MINUTE=240
RATE_LIMIT_AUTH_MAX_REQUESTS_PER_MINUTE=60
