# Runtime
BACKEND_IMAGE=docker.io/aksahoo1097/godamm-backend:replace-with-git-sha
BACKEND_PORT=8080

# MySQL
MYSQL_DATABASE=inventory_db
MYSQL_USER=inventory_app
MYSQL_PASSWORD=change_this_app_password
MYSQL_ROOT_PASSWORD=change_this_root_password
MYSQL_PORT=3306

# Backend DB runtime variables
DB_URL=jdbc:mysql://mysql:3306/inventory_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=inventory_app
DB_PASSWORD=change_this_app_password

# JWT
JWT_SECRET=replace_with_a_long_random_secret_value_of_32_chars_or_more
JWT_EXPIRATION_MS=86400000

# OTP
OTP_EXPIRATION_MINUTES=10

# CORS and HTTPS
CORS_ALLOWED_ORIGINS=https://godamm.mraks.dev,https://godamm.anjaliv.dev
REQUIRE_HTTPS=true

# Cache and Redis
CACHE_PROVIDER=redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_this_redis_password
REDIS_TIMEOUT=2s

# Mail server for OTP delivery
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=mailer@example.com
MAIL_PASSWORD=change_me

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS_PER_MINUTE=240
RATE_LIMIT_AUTH_MAX_REQUESTS_PER_MINUTE=60

# Optional JVM override (service default is already tuned for 4 GB)
# JAVA_OPTS=-Xms512m -Xmx1200m -XX:+UseG1GC -XX:MaxGCPauseMillis=200
